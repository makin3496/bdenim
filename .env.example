# ═══════════════════════════════════════════
# BDENIM — Environment Variables
# ═══════════════════════════════════════════
# Bu dosyayı .env.local olarak kopyala ve değerleri doldur
# cp .env.example .env.local

# Public URL of the Strapi instance used by the frontend.
# Local example: http://localhost:1337
# Production example: https://cms.example.com
NEXT_PUBLIC_STRAPI_URL=https://your-strapi-instance.example.com

# Optional/private token for protected Strapi endpoints and local scripts.
# Never commit a real token.
STRAPI_API_TOKEN=your_strapi_api_token_here

# Public site URL for frontend metadata and deployment configuration.
# Local example: http://localhost:3000
# Production example: https://your-vercel-domain.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-site.example.com
